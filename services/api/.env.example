# Prisma — local PostgreSQL (typical install listens on port 5432)
DATABASE_URL="postgresql://qrmeal:qrmeal@localhost:5432/qrmeal"

# If you use Docker Compose Postgres instead (mapped to host port 5433), use:
# DATABASE_URL="postgresql://qrmeal:qrmeal@localhost:5433/qrmeal"

JWT_SECRET="change-me-in-production"

# Cloudinary (optional, recommended for Render because local filesystem is ephemeral)
# If set, menu item images upload to Cloudinary and imageUrl will be a https URL.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional folder in Cloudinary
CLOUDINARY_FOLDER="qrmeal/menu-items"
